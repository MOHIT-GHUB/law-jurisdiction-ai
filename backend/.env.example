# ─────────────────────────────────────────────────────────────
#  LexAI — Environment Variables Template
#  USAGE: Copy this file to .env and fill in real values.
#         cp .env.example .env
#  WARNING: Never commit .env — it's in .gitignore
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
DEBUG=False

# HACKATHON: Set to True before demo to use mock API data.
# This means Congress.gov, Cornell LII, CourtListener calls
# are bypassed and realistic demo data is returned instead.
# Never crashes — even on bad wifi.
DEMO_MODE=True

# ── Database (matches docker-compose.yml) ────────────────────
DATABASE_URL=postgresql+asyncpg://lexai:lexai@localhost:5432/lexai

# ── Redis (matches docker-compose.yml) ───────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# ── Auth (JWT) ───────────────────────────────────────────────
# GENERATE A REAL KEY: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-real-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── LLM ──────────────────────────────────────────────────────
# Use gpt-4o-mini during development to save costs.
# Switch to gpt-4o for final demo for best quality.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── External Legal APIs ───────────────────────────────────────
# Congress.gov — free signup: https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# CourtListener — free, works without key (rate limited)
COURTLISTENER_API_KEY=

# Google Maps — needed for lawyer referral feature
# Leave blank to use demo data for lawyers
GOOGLE_MAPS_API_KEY=

# ── Context window ────────────────────────────────────────────
MAX_CONTEXT_MESSAGES=20
